{
  "expo": {
    "name": "TAMTAM",
    "slug": "TAMTAM",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "scheme": "tamtam",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pratishth.ourlink",
      "infoPlist": {
        "NSCameraUsageDescription": "TAMTAM needs access to your camera.",
        "NSPhotoLibraryUsageDescription": "TAMTAM needs access to your photos.",
        "NSMicrophoneUsageDescription": "TAMTAM needs access to your voice.",
        "NSFaceIDUsageDescription": "TAMTAM needs access to FaceID to secure your finances.",
        "NSLocationWhenInUseUsageDescription": "TAMTAM needs location access to show you on the map and find shared places.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TAMTAM needs background location to alert you when you are near shared memories and wishlist spots.",
        "NSLocationAlwaysUsageDescription": "TAMTAM needs background location to alert you when you are near shared memories.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "NSSupportsLiveActivities": false,
        "NSSupportsLiveActivitiesFrequentUpdates": false,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-location",
      "expo-notifications",
      "expo-task-manager",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f06a1fe6-a139-4470-a5c2-e1298f488019"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
